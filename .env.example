# Database (Turso)
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=

# Auth / JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Server
PORT=3001
CORS_ORIGIN=http://localhost:5173
# Optional: override rate limits (requests per 15 min). Defaults: auth=10, api=200 (prod), much higher in dev.
AUTH_RATE_LIMIT=
API_RATE_LIMIT=

# Frontend (Vite — must be prefixed with VITE_)
VITE_API_URL=http://localhost:3001
