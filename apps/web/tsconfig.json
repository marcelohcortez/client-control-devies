{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@client-control/shared": ["../../packages/shared/src/types.ts"]
    },
    "outDir": "dist",
    "noEmit": true
  },
  "include": ["src", "e2e"],
  "exclude": ["node_modules", "dist"]
}
